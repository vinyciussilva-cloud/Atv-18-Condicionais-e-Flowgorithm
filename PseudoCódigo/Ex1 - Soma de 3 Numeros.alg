algoritmo "Soma de Tres Numeros"

var

  n1, n2, n3, soma : real

inicio
  //  Entrada de Dados
  escreva("Digite o 1º número: ")
  leia(n1)
  escreva("Digite o 2º número: ")
  leia(n2)
  escreva("Digite o 3º número: ")
  leia(n3)
  soma <- n1 + n2 + n3
  escreva("Soma = ", soma)

fimalgoritmo


